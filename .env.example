# --- Data ---
# "mock" (in-memory dev data, live base untouched) or "airtable"
DATA_SOURCE=mock
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appAlp6BBobAiV0d6
# Set to "false" until the Location/Notes schema migration has been applied
# to the base the app points at (see README §Schema migration).
AIRTABLE_HAS_NEW_FIELDS=false
# Closed (collected / can't get / cancelled) orders older than this many
# months aren't loaded from Airtable; open orders always are.
# ORDERS_WINDOW_MONTHS=12

# Events base schema flags (leave false until the documented migrations land)
EVENTS_AIRTABLE_HAS_LOCATION=false
EVENTS_AIRTABLE_HAS_PHASE2=false
EVENTS_AIRTABLE_HAS_EVENT_LOCATION=false

# --- Luma event integration ---
# Keep "mock" until the calendar key(s) have been added and validated. In live
# mode, Backstage reads aggregate event/guest totals. The only external write
# is the explicit "Push private draft to Luma" button.
LUMA_MODE=mock
# One key per calendar (Luma Settings → Developer). The integration verifies
# each key against Luma before using it, so the two keys cannot be swapped.
LUMA_SIMPLY_API_KEY=
LUMA_PROLOGUE_API_KEY=
# Signing secret generated when /api/luma/webhook is registered in Luma.
LUMA_WEBHOOK_SECRET=

# --- Daily Briefing integrations (all optional — mock data until set) ---
# Wrap-ups + urgent alerts persist to the general-purpose "Backstage" base,
# found BY NAME via the meta API — no base-id env var needed. Requirements
# on AIRTABLE_API_KEY: the Backstage base in its access list + the
# schema.bases:read scope. Optional override if the lookup can't be used:
# BACKSTAGE_AIRTABLE_BASE_ID=
# Deputy roster + tasks (spec §2/§4). Permanent service-account token; the
# app maps Deputy locations to venues by NAME (Prologue/Weir Mill,
# Simply/Bramhall). Optional numeric overrides if a name doesn't match:
# DEPUTY_LOCATION_ID_PROLOGUE= / DEPUTY_LOCATION_ID_SIMPLY=
DEPUTY_HOSTNAME=
DEPUTY_API_TOKEN=
# Slack on-shift chatter (spec §8). Bot needs channels:history + users:read
# and must be invited to both channels; values are channel IDs (C…).
SLACK_BOT_TOKEN=
SLACK_CHANNEL_PRO_ON_SHIFT=
SLACK_CHANNEL_SB_ON_SHIFT=

# --- Book Clubs + Ordering Hub ---
# Clubs data lives in the LIVE "Book Clubs" Airtable base and hub tables in
# the "Backstage" base — both found BY NAME (token needs both bases in its
# access list + schema.bases:read). Optional overrides:
# BOOKCLUBS_AIRTABLE_BASE_ID=
# (BACKSTAGE_AIRTABLE_BASE_ID is shared with the Daily Briefing above.)
# Stripe — mock mode never touches Stripe. Restricted key (Customers /
# Subscriptions / Invoices; start read-only, upgrade for write actions).
STRIPE_SECRET_KEY=
# Webhook endpoint signing secret (see docs/clubs-hub-migration.md §3).
STRIPE_WEBHOOK_SECRET=

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Comma-separated existing Clerk emails used only to seed first/break-glass
# Admin access. Admins assigned through the UI are stored in Clerk metadata.
PERMISSIONS_BOOTSTRAP_ADMIN_EMAILS=

# --- Local dev only (ignored in production builds) ---
# DEV_AUTH_BYPASS=1
# DEV_AUTH_NAME=Ben
# DEV_AUTH_ROLE=manager
