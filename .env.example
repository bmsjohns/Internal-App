# --- Data ---
# "mock" (in-memory dev data, live base untouched) or "airtable"
DATA_SOURCE=mock
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appAlp6BBobAiV0d6
# Set to "false" until the Location/Notes schema migration has been applied
# to the base the app points at (see README §Schema migration).
AIRTABLE_HAS_NEW_FIELDS=false

# Events base schema flags (leave false until the documented migrations land)
EVENTS_AIRTABLE_HAS_LOCATION=false
EVENTS_AIRTABLE_HAS_PHASE2=false
EVENTS_AIRTABLE_HAS_EVENT_LOCATION=false

# --- Daily Briefing integrations (all optional — mock data until set) ---
# Wrap-ups + urgent alerts persistence: the general-purpose "Backstage"
# Airtable base (tables "Briefing Wrap-ups" / "Briefing Alerts"). The shared
# AIRTABLE_API_KEY token must have this base in its scope.
BACKSTAGE_AIRTABLE_BASE_ID=
# Deputy roster + tasks (spec §2/§4). Permanent service-account token; the
# OPUNIT vars map Deputy OperationalUnit/Company ids to the two venues
# (comma-separated if a venue spans several units).
DEPUTY_HOSTNAME=
DEPUTY_API_TOKEN=
DEPUTY_OPUNIT_PROLOGUE=
DEPUTY_OPUNIT_SIMPLY=
# Slack on-shift chatter (spec §8). Bot needs channels:history + users:read
# and must be invited to both channels; values are channel IDs (C…).
SLACK_BOT_TOKEN=
SLACK_CHANNEL_PRO_ON_SHIFT=
SLACK_CHANNEL_SB_ON_SHIFT=

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Local dev only (ignored in production builds) ---
# DEV_AUTH_BYPASS=1
# DEV_AUTH_NAME=Ben
# DEV_AUTH_ROLE=manager
